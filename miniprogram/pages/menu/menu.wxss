/* 扫码提示 */
.scan-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
}

.scan-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.scan-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 60rpx;
}

/* 菜单页面 */
.menu-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 餐桌头部 */
.table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
}

.table-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.table-no {
  padding: 8rpx 24rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 30rpx;
  font-weight: 600;
}

.table-capacity {
  color: #666;
  font-size: 26rpx;
}

.rescan-btn {
  font-size: 24rpx;
  padding: 12rpx 20rpx;
}

/* 分类导航 */
.category-nav {
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
}

.category-item.active {
  background: #1890ff;
  color: #fff;
}

/* 菜品列表 */
.dishes-list {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.dish-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.dish-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.dish-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dish-tags {
  margin-bottom: 12rpx;
}

.dish-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.dish-price {
  font-size: 34rpx;
}

.dish-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  font-size: 32rpx;
  color: #666;
}

.qty-btn.add-btn {
  background: #1890ff;
  color: #fff;
}

.qty-num {
  min-width: 40rpx;
  text-align: center;
  font-weight: 600;
}

.sold-out {
  color: #999;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 80rpx;
  color: #999;
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.cart-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cart-icon {
  font-size: 48rpx;
}

.cart-badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: -24rpx;
  margin-top: -32rpx;
}

.cart-total {
  margin-left: 16rpx;
}

.cart-total .price {
  font-size: 40rpx;
}

.submit-btn {
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
}

/* 购物车弹窗 */
.cart-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.cart-modal.show {
  opacity: 1;
  visibility: visible;
}

.cart-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 32rpx;
  font-weight: 600;
}

.cart-clear {
  color: #999;
  font-size: 26rpx;
  font-weight: normal;
}

.cart-items {
  max-height: 400rpx;
  padding: 20rpx 32rpx;
}

.cart-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-item-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.cart-item-name {
  font-weight: 500;
}

.cart-item-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.cart-item-remark {
  width: 100%;
  padding: 12rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.cart-form {
  padding: 20rpx 32rpx;
  border-top: 1rpx solid #eee;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 120rpx;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.cart-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-total-row {
  font-size: 28rpx;
}

.cart-total-price {
  font-size: 44rpx;
}

.order-btn {
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
}
