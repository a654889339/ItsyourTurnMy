/* 订单页面 */
.orders-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 扫码提示 */
.scan-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
}

.scan-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.scan-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 60rpx;
}

/* 订单容器 */
.orders-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 餐桌头部 */
.table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.table-info {
  display: flex;
  align-items: center;
}

.table-no {
  padding: 8rpx 24rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 30rpx;
  font-weight: 600;
}

.rescan-btn {
  font-size: 24rpx;
  padding: 12rpx 20rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 订单列表 */
.orders-list {
  flex: 1;
  padding: 20rpx;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.order-status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.order-status.confirmed {
  background: #e6f7ff;
  color: #1890ff;
}

.order-status.preparing {
  background: #f6ffed;
  color: #52c41a;
}

.order-status.ready {
  background: #f9f0ff;
  color: #722ed1;
}

.order-status.completed {
  background: #f5f5f5;
  color: #999;
}

.order-status.cancelled {
  background: #fff1f0;
  color: #f5222d;
}

/* 菜品摘要 */
.order-summary {
  padding: 20rpx 24rpx;
}

.dish-names {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fafafa;
}

.order-info {
  display: flex;
  flex-direction: column;
}

.order-no-text {
  font-size: 22rpx;
  color: #999;
}

.item-count {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.order-total {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.total-price {
  font-size: 34rpx;
  font-weight: 600;
}

.view-detail {
  font-size: 22rpx;
  color: #1890ff;
  margin-top: 4rpx;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.detail-modal.show {
  opacity: 1;
  visibility: visible;
}

.detail-panel {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.detail-modal.show .detail-panel {
  transform: translateY(0);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #eee;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #999;
}

.detail-status {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
}

.status-badge {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
}

.status-badge.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-badge.confirmed {
  background: #e6f7ff;
  color: #1890ff;
}

.status-badge.preparing {
  background: #f6ffed;
  color: #52c41a;
}

.status-badge.ready {
  background: #f9f0ff;
  color: #722ed1;
}

.status-badge.completed {
  background: #f5f5f5;
  color: #999;
}

.status-badge.cancelled {
  background: #fff1f0;
  color: #f5222d;
}

.status-time {
  font-size: 24rpx;
  color: #666;
}

.detail-order-no {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #999;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 详情菜品列表 */
.detail-items {
  max-height: 40vh;
  overflow-y: auto;
  padding: 0 24rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-remark {
  font-size: 24rpx;
  color: #999;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-qty {
  font-size: 26rpx;
  color: #999;
  margin-right: 20rpx;
}

.item-price {
  font-size: 28rpx;
  color: #333;
  min-width: 100rpx;
  text-align: right;
}

/* 详情备注 */
.detail-remark {
  padding: 20rpx 24rpx;
  background: #fffbe6;
  font-size: 26rpx;
}

.detail-remark .remark-label {
  color: #fa8c16;
}

.detail-remark .remark-text {
  color: #666;
}

/* 顾客信息 */
.detail-customer {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  border-top: 1rpx solid #f0f0f0;
}

/* 详情合计 */
.detail-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-top: 1rpx solid #eee;
  background: #fff;
}

.detail-total .total-label {
  font-size: 30rpx;
  color: #333;
}

.detail-total .total-price {
  font-size: 40rpx;
  font-weight: 600;
}

/* 通用价格样式 */
.price {
  color: #ff4d4f;
}
